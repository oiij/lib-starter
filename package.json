{
  "name": "ts-starter",
  "type": "module",
  "version": "0.0.1",
  "description": "A starter template for TypeScript projects",
  "author": "oiij",
  "license": "MIT",
  "homepage": "https://github.com/oiij/ts-starter",
  "repository": {
    "type": "git",
    "url": "git@github.com:oiij/ts-starter.git"
  },
  "bugs": "https://github.com/oiij/ts-starter/issues",
  "keywords": [
    "ts-starter"
  ],
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsc --noEmit && tsdown",
    "start": "pnpx esno src/index.ts",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type:check": "tsc --noEmit",
    "release": "pnpx bumpp && npm publish",
    "awe": "pnpx are-we-esm",
    "nmi": "pnpx node-modules-inspector",
    "update:deps": "pnpx taze -w && pnpm i",
    "cz": "czg",
    "commit": "git pull && git add -A && pnpm cz && git push",
    "prepublishOnly": "pnpm build",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@oiij/tsconfig": "^0.0.4",
    "@types/node": "^25.9.3",
    "@vitest/ui": "^4.1.8",
    "commitlint": "^21.0.2",
    "cz-git": "^1.13.1",
    "czg": "^1.13.1",
    "eslint": "^10.4.1",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm type:check"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm lint:fix"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
